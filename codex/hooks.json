{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$HOME/.codex/hooks/pre_tool_use.py\"",
            "timeout": 5,
            "statusMessage": "安全性を確認しています"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$HOME/.codex/hooks/user_prompt_submit.py\"",
            "timeout": 5,
            "statusMessage": "秘密情報を確認しています"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$HOME/.codex/hooks/post_tool_use.py\"",
            "timeout": 5,
            "statusMessage": "編集内容を確認しています"
          }
        ]
      }
    ]
  }
}
